generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DbConnection {
  id          String     @id @default(uuid())
  name        String
  host        String
  port        Int        @default(5432)
  database    String
  username    String
  password    String
  createdAt   DateTime   @default(now())
  queryLogs   QueryLog[]

  @@map("db_connections")
}

model QueryLog {
  id               String         @id @default(uuid())
  originalQuery    String
  optimizedQuery   String?
  executionTime    Float?
  isSlow           Boolean        @default(false)
  explainPlan      Json?
  isSyntaxValid    Boolean?
  errorCategory    String?
  postgresError    String?
  joinTypeCount    Int            @default(0)
  logicFlaws       Json?
  explanation      String?
  connectionId     String?
  connection       DbConnection?  @relation(fields: [connectionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt        DateTime       @default(now())
}

model MLModelStats {
  id                Int      @id @default(autoincrement())
  success           Boolean  @default(false)
  accuracy          Float?
  recordCount       Int?
  performanceRecords Int?
  syntaxRecords     Int?
  logicRecords      Int?
  unknownRecords    Int?
  confusionMatrix   Json?
  message           String?
  updatedAt         DateTime @updatedAt
}

model orders {
  id         Int       @id @default(autoincrement())
  user_id    Int
  product_id Int
  quantity   Int?
  total      Decimal?  @db.Decimal(10, 2)
  status     String?   @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  products   products  @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_orders_user_id")
}

model products {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String?
  price       Decimal?  @db.Decimal(10, 2)
  category    String?   @db.VarChar(100)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  orders      orders[]

  @@index([id], map: "idx_products_id")
}

model users {
  id         Int       @id @default(autoincrement())
  email      String    @db.VarChar(255)
  first_name String?   @db.VarChar(100)
  last_name  String?   @db.VarChar(100)
  address    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  orders     orders[]

  @@index([id], map: "idx_users_id")
}
